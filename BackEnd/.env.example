# ====================================
# QUANTUMCODE BACKEND - ENVIRONMENT VARIABLES
# ====================================
# Copy this file to .env and fill in the actual values
# IMPORTANT: NEVER commit .env file with real credentials to Git!
# ====================================

# Server Configuration
PORT=3000
NODE_ENV=production

# ====================================
# DATABASE - MongoDB Atlas
# ====================================
# Get your MongoDB connection string from MongoDB Atlas:
# https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
DB_CONNECT_STRING=mongodb+srv://username:password@cluster.mongodb.net/quantumcode?retryWrites=true&w=majority

# ====================================
# AUTHENTICATION
# ====================================
# JWT Key - Use a strong random string for security
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_KEY=your-super-secret-jwt-key-here-use-strong-random-string

# ====================================
# REDIS - For Token Blacklisting (Optional)
# ====================================
# Get Redis credentials from Redis Labs: https://redis.com/try-free/
REDIS_HOST=redis-xxxxx.c266.us-east-1-3.ec2.cloud.redislabs.com
REDIS_PORT=17078
REDIS_PASS=your-redis-password-here

# ====================================
# JUDGE0 API - Code Execution
# ====================================
# Get your Judge0 API key from: https://judge0.com/
# Free tier available
JUDGE0_API_KEY=your-judge0-api-key-here

# ====================================
# FRONTEND URL - For CORS
# ====================================
# This should be your deployed frontend URL from Vercel
# During development: http://localhost:5173
# In production: https://your-app.vercel.app
FRONTEND_URL=https://your-vercel-domain.vercel.app
